{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@pageobjects/*": ["pageobjects/*"],
      "@testdata/*": ["testdata/*"],
      "@helper/*": ["helper/*"]
    }
  },
  "include": ["**/*.ts"]
}
